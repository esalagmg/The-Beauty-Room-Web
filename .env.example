# ─────────────────────────────────────────────────────────────
# The Beauty Room — environment variables
# Copy to `.env.local` and fill in. The site runs WITHOUT these
# (it falls back to built-in data); set them to enable the database,
# admin panel, bookings and notifications.
# ─────────────────────────────────────────────────────────────

# Supabase (Settings → API in your Supabase project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only secret — NEVER expose to the browser. Used by admin + bookings.
SUPABASE_SERVICE_ROLE_KEY=

# Owner notifications
RESEND_API_KEY=
OWNER_NOTIFY_EMAIL=
# Sender for all emails. Leave blank to use Resend's shared address
# (onboarding@resend.dev) — works with NO domain, but only delivers to your own
# Resend account email. Set to a verified branded address once your domain is
# verified, e.g.  The Beauty Room <bookings@thebeautyroombynilu.lk>
EMAIL_FROM=
# Optional free instant ping to the owner's phone (Telegram bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Public site URL (used in confirmation links). e.g. https://thebeautyroombynilu.lk
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Spam protection (Cloudflare Turnstile) — optional in dev
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
